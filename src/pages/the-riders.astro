  // ── DOM refs ──────────────────────────────────────────────────────────────
  const overlay     = document.getElementById('rider-overlay')!;
  const closeBtn    = document.getElementById('overlay-close')!;
  const cardImg     = document.getElementById('overlay-card-img') as HTMLImageElement;
  const storyTitle  = document.getElementById('overlay-story-title')!;
  const nameEl      = document.getElementById('overlay-name')!;
  const nicknameEl  = document.getElementById('overlay-nickname')!;
  const statsEl     = document.getElementById('overlay-stats')!;
  const bioEl       = document.getElementById('overlay-bio')!;
  const partyWrap   = document.getElementById('overlay-party-fact-wrap')!;
  const partyText   = document.getElementById('overlay-party-text')!;

  // ── Open ──────────────────────────────────────────────────────────────────
  function openOverlay(slug: string) {
    const rider = RIDERS[slug];
    if (!rider) return;

    cardImg.src = `/images/cards/${slug}-front.png`;
    cardImg.alt = rider.name;
    storyTitle.textContent = rider.storyTitle || '';
    nameEl.textContent     = rider.name;
    nicknameEl.textContent = rider.nickname || '';

    statsEl.innerHTML = rider.stats
      .map(s => `<dt>${s.label}</dt><dd>${s.value}</dd>`)
      .join('');

    bioEl.textContent = rider.bio;

    if (rider.partyFact) {
      partyText.textContent = rider.partyFact;
      partyWrap.style.display = '';
    } else {
      partyWrap.style.display = 'none';
    }

    overlay.classList.add('is-open');
    document.body.style.overflow = 'hidden';
    closeBtn.focus();
  }

  // ── Close ─────────────────────────────────────────────────────────────────
  function closeOverlay() {
    overlay.classList.remove('is-open');
    document.body.style.overflow = '';
  }

  // ── Events ────────────────────────────────────────────────────────────────
  document.querySelectorAll<HTMLButtonElement>('.card-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const slug = btn.dataset.slug;
      if (slug) openOverlay(slug);
    });
  });

  closeBtn.addEventListener('click', closeOverlay);
  overlay.addEventListener('click', closeOverlay);
  document.getElementById('overlay-content')!.addEventListener('click', e => e.stopPropagation());

  document.addEventListener('keydown', (e: KeyboardEvent) => {
    if (e.key === 'Escape') closeOverlay();
  });

  // ── Page load animations ──────────────────────────────────────────────────
  gsap.fromTo('#riders-bg',
    { scale: 1.07, transformOrigin: 'center center' },
    { scale: 1, duration: 2.5, ease: 'power2.out' }
  );

  const tl = gsap.timeline({ defaults: { ease: 'power3.out' } });

  tl.from('#riders-eyebrow', { opacity: 0, y: 10, duration: 0.45 }, 0.3);
  tl.from('#riders-headline', { opacity: 0, y: -48, duration: 0.65, ease: 'power4.out' }, 0.5);
  tl.from('#riders-red', { opacity: 0, x: 24, duration: 0.5, ease: 'back.out(1.3)' }, 0.8);
  tl.from('#riders-rule', { scaleX: 0, transformOrigin: 'left center', duration: 0.45, ease: 'power2.out' }, 1.0);

  // ── Card deal-in ──────────────────────────────────────────────────────────
  gsap.from('.card-btn', {
    opacity: 0,
    y: 60,
    scale: 0.88,
    rotation: () => gsap.utils.random(-5, 5),
    duration: 0.65,
    stagger: { amount: 0.45, from: 'start' },
    ease: 'back.out(1.2)',
    scrollTrigger: {
      trigger: '#card-grid',
      start: 'top 82%',
    },
  });
</script>
