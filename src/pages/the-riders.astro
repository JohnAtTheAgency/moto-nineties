---
import Layout from '../layouts/Layout.astro';

const riders = [
  { slug: 'mcgrath',    name: 'Jeremy McGrath',    title: '"Showtime"',        number: '2' },
  { slug: 'emig',       name: 'Jeff Emig',          title: '"Fro"',             number: '8' },
  { slug: 'pastrana',   name: 'Travis Pastrana',    title: '"199"',             number: '199' },
  { slug: 'hart',       name: 'Carey Hart',         title: '"Hart Attack"',     number: '13' },
  { slug: 'carmichael', name: 'Ricky Carmichael',   title: '"The GOAT"',        number: '4' },
  { slug: 'hughes',     name: 'Ryan Hughes',        title: '"Ryno"',            number: '7' },
  { slug: 'stephenson', name: 'Denny Stephenson',   title: '"Showdown"',        number: '11' },
];
---

<Layout title="The Riders — Moto Nineties">

  <!-- ── HEADER ────────────────────────────────────────────────────────────── -->
  <section class="pt-32 pb-12 px-5 bg-ink">
    <div class="max-w-4xl mx-auto">
      <p class="font-sans text-smoke text-xs tracking-[0.15em] uppercase mb-4">Hi Flyers</p>
      <h1 class="font-display text-5xl sm:text-7xl uppercase text-paper leading-none">
        The<br/><span class="text-red">Riders.</span>
      </h1>
      <span class="red-rule mt-6 block"></span>
    </div>
  </section>

  <!-- ── CARD GRID ─────────────────────────────────────────────────────────── -->
  <section class="px-5 pb-20 bg-ink">
    <div class="max-w-4xl mx-auto grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-4 sm:gap-6" id="card-grid">
      {riders.map((rider) => (
        <div class="card-flip-wrapper" data-rider={rider.slug}>
          <div class="card-flip-inner">
            <!-- Front -->
            <div class="card-face card-front">
              <img
                src={`/images/cards/${rider.slug}-front.png`}
                alt={rider.name}
                class="w-full h-full object-cover"
                loading="lazy"
              />
            </div>
            <!-- Back -->
            <div class="card-face card-back">
              <img
                src={`/images/cards/${rider.slug}-back.png`}
                alt={`${rider.name} — card back`}
                class="w-full h-full object-cover"
                loading="lazy"
              />
            </div>
          </div>
          <p class="mt-2 font-display text-xs uppercase tracking-widest text-smoke truncate">{rider.name}</p>
        </div>
      ))}
    </div>
    <p class="text-center text-smoke text-xs font-sans mt-8 tracking-widest uppercase">Tap a card to flip</p>
  </section>

</Layout>

<style>
  .card-flip-wrapper {
    cursor: pointer;
    perspective: 800px;
  }

  .card-flip-inner {
    position: relative;
    width: 100%;
    aspect-ratio: 2.5 / 3.5;
    transform-style: preserve-3d;
    transition: transform 0.55s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .card-flip-wrapper.flipped .card-flip-inner {
    transform: rotateY(180deg);
  }

  .card-face {
    position: absolute;
    inset: 0;
    backface-visibility: hidden;
    -webkit-backface-visibility: hidden;
    overflow: hidden;
    border: 1px solid rgba(240, 235, 227, 0.08);
  }

  .card-back {
    transform: rotateY(180deg);
  }
</style>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  // Card flip on tap/click
  document.querySelectorAll('.card-flip-wrapper').forEach(card => {
    card.addEventListener('click', () => card.classList.toggle('flipped'));
  });

  // Staggered entrance
  gsap.from('.card-flip-wrapper', {
    opacity: 0,
    y: 40,
    duration: 0.6,
    stagger: 0.07,
    ease: 'power2.out',
    scrollTrigger: {
      trigger: '#card-grid',
      start: 'top 80%',
    },
  });
</script>
