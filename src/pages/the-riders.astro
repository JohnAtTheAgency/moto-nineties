      partyFact: 'The only rider who made trainers nervous.',
    },
    stephenson: {
      name: 'Denny Stephenson',
      nickname: '"Debo"',
      storyTitle: 'The Big Personality',
      stats: [
        { label: 'Hometown',      value: "Wherever the laughter's loudest" },
        { label: 'Ride',          value: 'A 125 that screamed almost as loud as he did' },
        { label: 'Claim to Fame', value: 'Talent + attitude + unlimited storytelling energy' },
