---
import Layout from '../layouts/Layout.astro';

const riders = [
  { slug: 'pastrana',    name: 'Travis Pastrana'    },
  { slug: 'hughes',      name: 'Ryan Hughes'        },
  { slug: 'carmichael',  name: 'Ricky Carmichael'   },
  { slug: 'antunez',     name: 'Buddy Antunez'      },
  { slug: 'mcgrath',     name: 'Jeremy McGrath'     },
  { slug: 'emig',        name: 'Jeff Emig'          },
  { slug: 'supermac',    name: 'Supermac McGrath'   },
  { slug: 'hart',        name: 'Carey Hart'         },
  { slug: 'lawrence',    name: 'Phil Lawrence'      },
  { slug: 'stephenson',  name: 'Denny Stephenson'   },
  { slug: 'us-open',     name: '1999 US Open'       },
  { slug: 'fro-fans',    name: 'Fro Fans'           },
  { slug: 'crusty',      name: 'Crusty Demons'      },
  { slug: 'club-rubber', name: 'Club Rubber'        },
  { slug: 'havasu',      name: 'Lake Havasu'        },
  { slug: 'button',      name: 'Jimmy Button'       },
  { slug: 'launi',       name: 'Launi'              },
  { slug: 'steel-roots', name: 'Steel Roots'        },
  { slug: 'albrecht',    name: 'Jeremy Albrecht'    },
  { slug: 'mc-vs-fro',   name: 'MC vs FRO'          },
  { slug: 'norfolk',     name: 'Skip Norfolk'       },
  { slug: 'des-nations', name: 'Des Nations 1996'   },
  { slug: '1997',        name: '1997'               },
];
---

<Layout title="The Riders — Moto Nineties">

  <!-- ── PAGE WRAPPER with background ─────────────────────────────────────── -->
  <div class="relative">
    <img
      src="/images/BlackScratch.jpg"
      alt=""
      id="riders-bg"
      class="absolute inset-0 w-full h-full object-cover pointer-events-none"
      aria-hidden="true"
    />

    <!-- ── HEADER ──────────────────────────────────────────────────────────── -->
    <section class="relative pt-32 pb-12 px-5">
      <div class="max-w-4xl mx-auto">
        <p id="riders-eyebrow" class="font-sans text-smoke text-xs tracking-[0.15em] uppercase mb-4">Hi Flyers</p>
        <h1 id="riders-headline" class="font-display text-5xl sm:text-7xl uppercase text-paper leading-none">
          The<br/><span id="riders-red" class="text-red">Riders.</span>
        </h1>
        <span id="riders-rule" class="red-rule mt-6 block"></span>
      </div>
    </section>

    <!-- ── CARD GRID ────────────────────────────────────────────────────────── -->
    <section class="relative px-5 pb-20">
      <div class="max-w-4xl mx-auto grid grid-cols-3 gap-4 sm:gap-6" id="card-grid">
        {riders.map((rider) => (
          <button
            class="card-btn text-left group"
            data-slug={rider.slug}
            aria-label={`View ${rider.name}`}
          >
            <div class="relative overflow-hidden" style="aspect-ratio: 2.5 / 3.5;">
              <img
                src={`/images/cards/${rider.slug}-front.png`}
                alt={rider.name}
                class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
                loading="lazy"
              />
              <div class="absolute inset-0 opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex items-center justify-center" style="background: rgba(239, 167, 59, 0.9);">
                <span style="font-family: 'Permanent Marker', cursive; color: #080808; font-size: 1.1rem;">
                  View Profile
                </span>
              </div>
            </div>
            <p class="mt-2 font-display text-xs uppercase tracking-widest text-smoke truncate group-hover:text-paper transition-colors duration-200">
              {rider.name}
            </p>
          </button>
        ))}
      </div>
      <p class="text-center text-smoke text-xs font-sans mt-8 tracking-widest uppercase">
        Select a rider
      </p>
    </section>
  </div><!-- end page wrapper -->

  <!-- ── RIDER OVERLAY ──────────────────────────────────────────────────────── -->
  <div
    id="rider-overlay"
    role="dialog"
    aria-modal="true"
    aria-label="Rider profile"
  >
    <div id="overlay-backdrop" class="absolute inset-0"></div>

    <button id="overlay-close" aria-label="Close">
      <svg width="18" height="18" viewBox="0 0 18 18" fill="none">
        <path d="M1 1l16 16M17 1L1 17" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
      </svg>
    </button>

    <div id="overlay-content">

      <div id="overlay-card-wrap">
        <img id="overlay-card-img" src="" alt="" />
      </div>

      <div id="overlay-text">
        <p id="overlay-story-title"></p>
        <div id="overlay-name-block">
          <h2 id="overlay-name"></h2>
          <p id="overlay-nickname"></p>
        </div>
        <span class="red-rule block" style="margin-bottom: 1.5rem;"></span>
        <dl id="overlay-stats"></dl>
        <p id="overlay-bio"></p>
        <div id="overlay-party-fact-wrap">
          <p id="overlay-party-label">Party Fact</p>
          <p id="overlay-party-text"></p>
        </div>
      </div>

    </div>
  </div>

</Layout>

<style>
  .card-btn {
    background: none;
    border: none;
    padding: 0;
    cursor: pointer;
    display: block;
    width: 100%;
  }

  #rider-overlay {
    position: fixed;
    inset: 0;
    z-index: 60;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: clamp(1rem, 4vw, 2.5rem);
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.2s ease-out;
  }

  #rider-overlay.is-open {
    opacity: 1;
    pointer-events: all;
  }

  #overlay-backdrop {
    background: rgba(8, 8, 8, 0.92);
  }

  #overlay-close {
    position: absolute;
    top: clamp(1rem, 3vw, 1.75rem);
    right: clamp(1rem, 3vw, 1.75rem);
    z-index: 10;
    background: none;
    border: none;
    padding: 0.5rem;
    color: rgba(240, 235, 227, 0.35);
    cursor: pointer;
    transition: color 0.15s ease;
  }

  #overlay-close:hover {
    color: rgba(240, 235, 227, 0.9);
  }

  #overlay-content {
    position: relative;
    z-index: 10;
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
    width: 100%;
    max-width: 900px;
    max-height: calc(100svh - 4rem);
    overflow-y: auto;
    transform: translateY(24px);
    transition: transform 0.28s ease-out;
  }

  #rider-overlay.is-open #overlay-content {
    transform: translateY(0);
  }

  @media (min-width: 640px) {
    #overlay-content {
      grid-template-columns: 260px 1fr;
      align-items: start;
      overflow-y: visible;
    }
  }

  #overlay-card-img {
    display: block;
    width: 100%;
    max-width: 220px;
    margin: 0 auto;
    aspect-ratio: 2.5 / 3.5;
    object-fit: cover;
    transform: rotate(-1.5deg);
    box-shadow: 0 24px 64px rgba(0, 0, 0, 0.7);
  }

  @media (min-width: 640px) {
    #overlay-card-img {
      max-width: 100%;
      transform: rotate(-2deg);
    }
  }

  #overlay-text {
    padding-bottom: 2rem;
  }

  #overlay-story-title {
    font-family: 'Anton', sans-serif;
    font-size: 0.65rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: #d81d28;
    margin: 0 0 0.75rem;
  }

  #overlay-name {
    font-family: 'Anton', sans-serif;
    font-size: clamp(2rem, 5vw, 3rem);
    text-transform: uppercase;
    color: #f0ebe3;
    line-height: 1.05;
    margin: 0 0 0.25rem;
  }

  #overlay-nickname {
    font-family: 'Permanent Marker', cursive;
    font-size: clamp(1.1rem, 2.5vw, 1.5rem);
    color: #efa73b;
    margin: 0 0 1.25rem;
  }

  #overlay-nickname:empty {
    display: none;
    margin: 0;
  }

  #overlay-stats {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 0.4rem 1.25rem;
    margin: 0 0 1.5rem;
  }

  #overlay-stats:empty {
    display: none;
    margin: 0;
  }

  #overlay-stats dt {
    font-family: 'Inter', sans-serif;
    font-size: 0.65rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #9a9a9a;
    padding-top: 0.1em;
    white-space: nowrap;
  }

  #overlay-stats dd {
    font-family: 'Inter', sans-serif;
    font-size: 0.8rem;
    color: rgba(240, 235, 227, 0.85);
    margin: 0;
    line-height: 1.5;
  }

  #overlay-bio {
    font-family: 'Inter', sans-serif;
    font-size: 0.875rem;
    line-height: 1.75;
    color: rgba(240, 235, 227, 0.65);
    margin: 0 0 1.5rem;
    max-width: 52ch;
  }

  #overlay-party-fact-wrap {
    border: 1px solid rgba(240, 235, 227, 0.08);
    background: rgba(240, 235, 227, 0.03);
    padding: 0.875rem 1rem;
  }

  #overlay-party-label {
    font-family: 'Inter', sans-serif;
    font-size: 0.6rem;
    font-weight: 600;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: #9a9a9a;
    margin: 0 0 0.35rem;
  }

  #overlay-party-text {
    font-family: 'Inter', sans-serif;
    font-size: 0.8rem;
    line-height: 1.65;
    color: rgba(240, 235, 227, 0.6);
    margin: 0;
  }

  #overlay-content {
    scrollbar-width: thin;
    scrollbar-color: rgba(240, 235, 227, 0.1) transparent;
  }
</style>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  // ── Rider data ────────────────────────────────────────────────────────────
  const RIDERS: Record<string, {
    name: string;
    nickname: string;
    storyTitle: string;
    stats: { label: string; value: string }[];
    bio: string;
    partyFact: string | null;
  }> = {
    pastrana: {
      name: 'Travis Pastrana',
      nickname: '"199"',
      storyTitle: "The Bay Bomber of '99",
      stats: [
        { label: 'Hometown',   value: 'Davidsonville, MD' },
        { label: 'Ride',       value: 'Suzuki RM125, fueled by blind optimism and the confidence of a fearless 15-year-old' },
        { label: 'Risk Level', value: '"Hold my Capri Sun."' },
      ],
      bio: "The best $10,000 Travis Pastrana ever lost (spent?) happened in the summer of 1999 when he attempted to backflip his RM125 into the San Francisco Bay, a rebellious move even in the alt world of action sports. The city gave a huge fine. ESPN never aired the clip, but the footage spilled from videos and Pastrana still cashes dividends from the move's impact. A factory-supported phenom not even old enough to race Pro Motocross, Pastrana was already upstaging the athletes he was preparing to race. The only true dual SX/MX + FMX threat, Pastrana chose freestyle when a pro racing career was a wide open option. That day on The Bay, FMX stopped flirting with insanity and fully moved in with it. The sport never looked back.",
      partyFact: "Pastrana did his run with Chuck Berry's \"Johnny B. Goode\" playing on the PA system. He loved leaning hard into the clean-cut, all-American good-kid image. Then he redefined what \"good behavior\" looked like on a dirt bike.",
    },
    hughes: {
      name: 'Ryan Hughes',
      nickname: '"Ryno"',
      storyTitle: 'The Warrior',
      stats: [
        { label: 'Hometown', value: 'Escondido, California' },
        { label: 'Ride',     value: 'Kawasaki KX250 & KX125. Chains optional.' },
        { label: 'Mindset',  value: 'Break before bend' },
      ],
      bio: "Ryan Hughes didn't race motocross. He waged war on it. Every moto was a battlefield, every lap a test of will, every injury something he refused to acknowledge. The race wasn't over even when the chain fell off his bike; he pushed to the finish. Uphill. Ryno rode with raw intensity, pushing past breaking points and carrying pain like fuel. A core member of the Moto Rat Pack, he brought grit, edge, and attitude to everything he lined up for. But he wasn't a one-note wonder; Hughes was dynamic, a thoughtful, funny spiritual seeker off the track, and a complete warrior on it. The nickname wasn't hype. It was a warning.",
      partyFact: 'The only rider who made trainers nervous.',
    },
    carmichael: {
      name: 'Ricky Carmichael',
      nickname: '"The GOAT"',
      storyTitle: 'The Fun Killer',
      stats: [
        { label: 'Hometown',   value: 'Tallahassee, Florida' },
        { label: 'Ride',       value: "Doesn't matter. He's still beating you on it." },
        { label: 'Reputation', value: "Party's Over" },
        { label: 'Moment',     value: '2000 Daytona Supercross win' },
      ],
      bio: "Ricky Carmichael didn't end the party. He simply didn't join it. Well, \"Meanie\" Jeanie didn't actually let him party (or even train) in SoCal. RC stayed grounded in Florida where he emptied 5-gallon jugs of race fuel faster than Bart Simpson could kill a Kwik-E-Mart Squishee. RC hated losing more than he liked winning and he didn't care about the \"scene.\" The era of style, vibes and late nights didn't gel with his discipline, structure and work ethic. He only cared about metrics that showed him getting better, every single day. When he dominated the 2000 Daytona Supercross, it felt like the beginning of the end. Not of racing, but an attitude. Some saw him as the bad guy, a killjoy. Turns out, he did know how to party — he just didn't do it with the competition.",
      partyFact: '"Taking it easy" still meant another 30 +2.',
    },
    antunez: {
      name: 'Buddy Antunez',
      nickname: '"Budman"',
      storyTitle: '',
      stats: [
        { label: 'Hometown', value: 'Southern California' },
        { label: 'Ride',     value: '125s and 250s (on the same night!)' },
        { label: 'Talent',   value: 'Speed, confidence, and just enough mischief' },
      ],
      bio: '"Budman" wasn\'t just a fun nickname for Buddy Antunez; he was literally the most likeable guy in the pits. Still is. As part of the Moto Rat Pack, he blended speed with personality and never lost credibility. Even though Antunez started 200 Supercross and Pro Motocross events in his career, his biggest racing success came in Arenacross where he won five consecutive championships and over 100 main events.',
      partyFact: 'Somehow fast, friendly, and still the center of the pits.',
    },
    mcgrath: {
      name: 'Jeremy McGrath',
      nickname: '"Showtime"',
      storyTitle: 'The First Nac Attack',
      stats: [
        { label: 'Hometown',  value: 'Sun City, California' },
        { label: 'Ride',      value: 'Honda CR250' },
        { label: 'Signature', value: 'The nac nac' },
        { label: 'Moment',    value: '1994 Supercross Series opener' },
      ],
      bio: "In 1994, Jeremy McGrath was so comfortable racing Supercross, he brought the BMX tricks that influenced his riding style to the stadiums. The nac nac, a leg-swinging aerial move no one in the motocross world had ever seen, wasn't about distance or speed — it was about style in the air. When he landed it cleanly in practice at the 1994 Supercross opener, jaws dropped, teammates thought he'd crashed and journalists didn't know what to call it. Soon the crowd knew it as the nac nac — the trick that helped turn motocross into something more expressive. The move didn't just become McGrath's trademark — it helped spark the earliest ideas of what would become freestyle motocross.",
      partyFact: null,
    },
    emig: {
      name: 'Jeff Emig',
      nickname: '"Fro"',
      storyTitle: 'Oats and Bran',
      stats: [
        { label: 'Profession', value: "Fake cereal / real flex / late-'90s moto artifact" },
        { label: 'Location',   value: 'The set of Frezno Smooth' },
        { label: 'Vibe',       value: 'Swagger with oats and bran' },
      ],
      bio: "The looser the program got, the better Jeff Emig fit. Only in the late '90s could a Supercross champion step onto the set of a cult moto film, holding a cereal box with his own name on it like it belonged there. Emig moved through Frezno Smooth cool, calm, and fully aware of the joke, never breaking character, never overplaying it. With a smirk that said oats and bran, he became the straight face inside moto satire, turning a fake product into a real moment. The movie split the moto media — praised by some, dismissed by others — but the image cut through all of it. Emig-O's outlived the debate, slipping into Moto Nineties folklore where explanation was never required. Fame didn't ask for context — it handed him a box and told him to act natural.",
      partyFact: "You didn't have to like the movie to remember the cereal. The pit board shot was filmed during an actual moto at the 1997 Steel City.",
    },
    supermac: {
      name: 'Jeremy McGrath',
      nickname: '"Supermac"',
      storyTitle: '',
      stats: [
        { label: 'Hometown',    value: 'The 1990s' },
        { label: 'Ride',        value: 'Whatever got him there first' },
        { label: 'Party Skill', value: 'Convincing his competition to party with him' },
      ],
      bio: "Jeremy McGrath was the guy most riders followed (figuratively AND literally) throughout the '90s. He set the pace, the tone and the trends. Fun came back to the top of the sport because he put it there. A Gen X party vibe flowed downhill from MC through the entire industry. And that might have been McGrath's secret power; he kept his friends close but his competition even closer by making sure they were invited to the parties. If MC was bonging beers and riding Jet Skis at Lake Havasu AND still winning, then that must have been the secret sauce, right? While others partied like McGrath, MC was still training harder than all of them. The beer bong was the profile; the work stayed invisible. That balance — serious discipline wrapped in real fun — is what made him untouchable. The '90s felt fun because the best rider in the world made dominance look easy.",
      partyFact: 'The vibe was real. The work ethic was not optional.',
    },
    hart: {
      name: 'Carey Hart',
      nickname: '"Hart Attack"',
      storyTitle: 'The Hart Attack',
      stats: [
        { label: 'Hometown',  value: 'Las Vegas' },
        { label: 'Ride',      value: 'Honda CR250' },
        { label: 'Signature', value: 'Fully extended superman seat grab' },
        { label: 'Moment',    value: '2000 Gravity Games' },
      ],
      bio: 'When you grow up doing homework by flashlight and shoveling asphalt for extra money, you learn work ethic early. Carey Hart calls himself "a tattooed scumbag from Las Vegas," but he had the work ethic — and the party vibe — needed to help push the struggling sport of FMX into the mainstream. When the hard realities of a traditional racing career didn\'t materialize, Hart didn\'t walk away. He dove into the emerging world of freestyle motocross and helped drag FMX out of VCRs and into the spotlight by jumping first, showing up first, and taking risks no one else was willing — or even thought possible. Carey Hart was a series of firsts. The first contest course was built by him and his dad. He was the first portable ramp test dummy. The first to expose freestyle to the punk crowd through the Warped Tour. And at the 2000 Gravity Games, the first to prove a backflip could be landed — advancing the sport to a new level. Hart proved freestyle wasn\'t a sideshow; it was something to be taken seriously — and it\'s kept growing ever since.',
      partyFact: 'Hart was inches away from becoming an accountant.',
    },
    lawrence: {
      name: 'Phil Lawrence',
      nickname: '"Factory Phil"',
      storyTitle: '"Factory Phil"',
      stats: [
        { label: 'Hometown',   value: 'Wherever the bikes are clean and the vibes are right' },
        { label: 'Ride',       value: 'Whatever the factory just polished' },
        { label: 'Superpower', value: 'Effortless cool + unexpected speed' },
      ],
      bio: "They called him \"Factory\" Phil because it didn't matter what team, bike, or level of support he had, Phil Lawrence looked straight off the factory floor. He was a key member of the Moto Rat Pack; he had effortless cool, sharp style, and a knack for being in the right place at the right time. In the heart of the '90s, he helped define freeride before it even had a name. In 1996, riding for a privateer team, he was a top five premier class Supercross rider and finished 5th in the championship. Off the track, Phil was the ultimate wingman, voted best in the role because he never forced the moment and never needed the spotlight to control it. He partied hard when the era demanded it then, quietly, changed gears when enough was enough. Phil wasn't just part of the scene — he helped set the tone, then showed you could walk away without losing who you were.",
      partyFact: "Don't ask him to relive the '90s. The Vault is sealed.",
    },
    stephenson: {
      name: 'Denny Stephenson',
      nickname: '"Debo"',
      storyTitle: 'The Big Personality',
      stats: [
        { label: 'Hometown',      value: "Wherever the laughter's loudest" },
        { label: 'Ride',          value: 'A 125 that screamed almost as loud as he did' },
        { label: 'Claim to Fame', value: 'Talent + attitude + unlimited storytelling energy' },
      ],
      bio: "Denny Stephenson opened the 1990s with a dominating run through the 125SX East championship (8 wins!), kicking off the decade with a #1 plate before anyone had gotten a chance to know who Jeremy McGrath and Jeff Emig were. Then \"Debo\" became the life of the party. A walking highlight reel of speed, swagger and unprintable quotes, Stephenson was aggressive, sharp, and fearless on the bike. Off the bike? The dude could light up a pit party. Whether he was winning, talking smack, stirring up fun, or just holding court with riders and fans, Denny had a presence you couldn't ignore. He was a racer with charisma so strong it should've come with a warning label.",
      partyFact: 'If you hung out with Denny, you woke up with stories... and maybe a headache.',
    },
    'us-open': {
      name: '1999 US Open',
      nickname: '',
      storyTitle: 'The Battle of the Eras',
      stats: [
        { label: 'Location',   value: 'MGM Grand, Las Vegas' },
        { label: 'Vibe',       value: 'Smoke machines, slot machines, unfinished business' },
        { label: 'Main Event', value: 'Emig vs. Carmichael — Old Guard vs. New Heat' },
      ],
      bio: "Jeff Emig was supposed to be washed up, done. Six weeks after being fired by Kawasaki (and two and half years since his last Supercross win), Emig showed up for the 1999 US Open of Supercross on a privateer Yamaha and walked away with the win and $100,000 prize. Emig, the veteran with championship scars, lined up against future champion Ricky Carmichael. Emig rode like a man with something to prove — smooth, calculated, dripping with swagger — while Carmichael charged with his trademark bulldog fury. When Emig crossed the line ahead of the future GOAT, the MGM arena erupted. Emig wasn't done yet and he closed out the 1990s with one last victory.",
      partyFact: 'If you listened closely, you could hear the MGM slot machines cheering.',
    },
    'fro-fans': {
      name: 'Fro Fans',
      nickname: '',
      storyTitle: 'The Afro-Wig Army',
      stats: [
        { label: 'Location', value: 'Any stadium or outdoor track with good nachos' },
        { label: 'Look',     value: 'Monster-sized Afros' },
        { label: 'Purpose',  value: 'Hype. Pure, chaotic hype' },
      ],
      bio: "Long before social media and spectator activation zones, Fro Fans found each other through hairdos. Don an oversized afro wig (shirt optional) and head straight for the fence line; your people were already waiting for you. The wigs (bigger the better) paid homage to Jeff \"Fro\" Emig's legendary nickname that started as a joke from Denny Stephenson. Fro fans brought unique energy to the races, jumping, screaming, chanting \"FRO\" when their icon was on the track. They were camera magnets, and Emig fed off the energy. The Fro fans became a symbol of personality, swagger, and that cool-kid energy Emig brought to the sport.",
      partyFact: 'Wearing the fro increased chances of meeting Jeff Emig by 47%.',
    },
    crusty: {
      name: 'Crusty Demons Film Crew',
      nickname: '',
      storyTitle: '',
      stats: [
        { label: 'Location', value: 'So-Cal ride spots, and later... the world' },
        { label: 'Gear',     value: 'Hi-8 cameras, duct tape, ropes, your chick' },
        { label: 'Mission',  value: 'Hold my beer' },
      ],
      bio: "The \"Crusty Demons of Dirt\" film crew brought the fun, the cameras and all the bad ideas; filming all the factory pros and dirt bike maniacs such as Mike Metzger, Linkogle, Hart, Seth Enslow, and Brian Deegan — all willingly threw down. The result wasn't just a series of riding films on VHS. It was the fuel for the explosion of Freestyle Motocross and the nightmare for the race industry that wanted these videos to fade into the sunset as fast as possible. Crusty's crews rolled tape in all conditions, with hangovers, and broke every rule they could find in the name of capturing epic freeride shots. Shoot first, run from the cops later. Without the brave (deranged?) Crusty film crew, freestyle might have stayed a rumor. With them, it became a revolution — and their creation melted a lot of Mylar.",
      partyFact: 'Crew was allegedly paid in gas money, high-fives, and anything left in the cooler.',
    },
    'club-rubber': {
      name: 'Club Rubber',
      nickname: '',
      storyTitle: '',
      stats: [
        { label: 'Profession',    value: 'Nightclub / pressure-release system / cultural collision point' },
        { label: 'Tools',         value: 'Theme nights, VIP rooms, strobe lights, scant clothing' },
        { label: 'Claim to Fame', value: 'The Monday night reset that became mandatory for the pro moto world' },
      ],
