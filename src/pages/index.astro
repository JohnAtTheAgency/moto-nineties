---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Moto Nineties — Coming Summer 2026">

  <!-- ── HERO ──────────────────────────────────────────────────────────────── -->
  <!--
    overflow-hidden is on the BG wrapper, NOT the section,
    so the bottom tape can bleed down over the next section.
  -->
  <section class="relative min-h-svh flex flex-col items-center justify-center" id="hero">

    <!-- Background — overflow-hidden keeps the photo contained -->
    <div class="absolute inset-0 overflow-hidden">
      <img
        src="/images/Moto-Nineties-Poster-Top.jpg"
        alt=""
        class="photo-bw w-full h-full object-cover object-top"
        id="hero-bg"
        style="transform: scale(1.04); transform-origin: center top;"
      />
      <!-- Blue poster overlay -->
      <div class="absolute inset-0"
           style="background: linear-gradient(to bottom, rgba(4,55,124,0.45) 0%, rgba(8,8,8,0.3) 40%, rgba(8,8,8,0.88) 80%, rgba(8,8,8,0.96) 100%);">
      </div>
      <!-- Red bleed at bottom -->
      <div class="absolute bottom-0 left-0 right-0 h-48"
           style="background: linear-gradient(to top, rgba(216,29,40,0.2) 0%, transparent 100%);">
      </div>
    </div>

    <!-- Logo + tagline — centered -->
    <div class="relative z-20 flex flex-col items-center text-center px-5 pt-6 md:pt-14 pb-20 md:pb-32">
      <img
        src="/images/Moto-Nineties-Full-Logo.png"
        alt="Moto Nineties"
        id="hero-logo"
        class="w-[322px] sm:w-[483px] md:w-[644px] drop-shadow-2xl"
      />
      <img
        id="hero-tagline"
        src="/images/Nineties-are-back-Headline.png"
        alt="The Nineties Are Back"
        class="mt-0 mb-5 drop-shadow-lg"
        style="width: clamp(260px, 45vw, 480px);"
      />
      <span id="hero-rule" class="red-rule mx-auto block mb-6"></span>

      <!-- Email capture -->
      <div id="hero-email-block" class="w-full max-w-lg">
        <p class="font-display text-red uppercase leading-none mb-3" style="font-size: clamp(1.5rem, 3vw, 2.25rem);">
          A Feature-Length Documentary
        </p>
        <p class="font-sans text-paper/80 text-sm mb-5">
          Pop-up premieres. Exclusive drops. First access to the film.
        </p>
        <form
          class="flex gap-0"
          onsubmit="handleHeroEmail(event)"
          id="hero-email-form"
        >
          <input
            type="email"
            name="email"
            placeholder="Enter your email"
            required
            class="flex-1 min-w-0 bg-white/70 border-0 px-4 py-3 text-sm text-ink placeholder:text-ink/50 focus:outline-none focus:bg-white/90 font-sans rounded-l-full transition-colors"
          />
          <button
            type="submit"
            class="bg-red text-paper px-5 py-3 text-xs font-display tracking-widest uppercase hover:bg-paper hover:text-ink transition-colors shrink-0 whitespace-nowrap rounded-r-full"
          >
            Get Early Access
          </button>
        </form>
      </div>
    </div>

    <!--
      Duct tape at the hero/war seam.
      position: absolute; bottom: -28px puts it overlapping the next section.
      z-index: 30 keeps it on top of both sections' content.
    -->
    <img
      src="/images/Moto-Nineties-Coming-Summer.png"
      alt=""
      class="absolute left-1/2 pointer-events-none z-30"
      style="bottom: 0; transform: translateX(-50%) translateY(50%); max-width: 600px; width: clamp(280px, 80%, 600px);"
      id="seam-tape"
    />

    <!-- Scroll hint -->
    <div class="absolute bottom-10 left-1/2 -translate-x-1/2 z-20 opacity-25" id="scroll-hint">
      <span class="block w-px h-10 bg-paper mx-auto"></span>
    </div>
  </section>

  <!-- ── THE WAR — white section ───────────────────────────────────────────── -->
  <section class="relative bg-white" id="war-section">
    <div class="max-w-5xl mx-auto px-5" style="padding-top: clamp(5rem, 10vw, 10rem); padding-bottom: 4rem;">

      <!-- Row 1: Headline — full width, centered, own line -->
      <div class="mb-5 text-center" id="war-headline-wrap">
        <p class="font-display text-red uppercase leading-none"
           id="war-headline"
           style="font-size: clamp(2.88rem, 5.47vw, 5.76rem); transform: rotate(3deg); display: inline-block;">
          The 90's Made Motocross<br/>Look Like a Party.
        </p>
      </div>

      <!-- Row 2: Image + text stacked vertically -->
      <div class="grid grid-cols-1 md:grid-cols-4 gap-6 md:gap-3 items-center">

        <!-- Image — 3/4 on desktop, full width on mobile -->
        <div class="md:col-span-3 md:-ml-5" id="war-image">
          <img
            src="/images/Moto-Nineties-McGrath-Emig-War-2.jpg"
            alt="McGrath vs Emig — It Was War"
            class="w-full"
          />
        </div>

        <!-- Copy — 1/4 on desktop -->
        <div class="md:col-span-1" id="war-copy">
          <p class="font-display text-blue uppercase leading-snug mb-4" style="font-size: clamp(1.15rem, 1.9vw, 1.55rem);">
            In the late nineties, two riders transformed motocross into something else entirely — a spectacle, a soap opera, a war.
          </p>
          <p class="font-sans text-ink/80 leading-relaxed mb-6" style="font-size: clamp(0.9rem, 1.1vw, 1rem);">
            Jeremy McGrath was the king. Jeff Emig was the challenger who wouldn't back down.
            What they called the fun era was anything but.
          </p>
          <div class="flex items-center gap-4">
            <span class="red-rule block shrink-0"></span>
            <a href="/the-film"
               class="font-display text-xs tracking-widest uppercase text-red hover:text-ink transition-colors">
              The Film →
            </a>
          </div>
        </div>

      </div>
    </div>
    <!-- Tear rip at seam -->
    <img src="/images/BaseRipCleanNew.png" alt="" aria-hidden="true" class="absolute left-1/2 pointer-events-none z-30 w-full"
         style="bottom: 0; transform: translateX(-50%) translateY(95%); max-width: 1600px;" />
  </section>

  <!-- ── BLOW-OUT PARTY ────────────────────────────────────────────────────── -->
  <section class="section relative" style="background: #04377c; padding-top: 8rem; padding-bottom: 8rem;" id="party-section">
    <div class="absolute inset-0 overflow-hidden pointer-events-none">
      <img src="/images/Blue-Scratch-background.jpg" alt="" class="w-full h-full object-cover opacity-25" />
    </div>
    <div class="relative z-10 max-w-3xl mx-auto text-center px-5">
      <img
        src="/images/Blow-Out-Party.webp"
        alt="It Was a Blow-Out Party"
        class="mx-auto mb-10 w-full"
        style="max-width: 720px;"
        id="party-headline"
      />
      <p class="font-display text-red uppercase tracking-widest text-sm mb-2">Now You're Invited.</p>
      <p class="font-display text-paper uppercase tracking-widest text-sm mb-8">Join the Mix</p>
      <div class="flex items-center justify-center gap-8">
        <a href="https://www.instagram.com/moto.nineties" target="_blank" rel="noopener"
           class="flex flex-col items-center gap-2 text-paper hover:text-red transition-colors">
          <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><circle cx="12" cy="12" r="4"/>
            <circle cx="17.5" cy="6.5" r="0.5" fill="currentColor" stroke="none"/>
          </svg>
          <span class="font-display text-xs tracking-widest uppercase">@moto.nineties</span>
        </a>
        <a href="https://www.facebook.com/motonineties" target="_blank" rel="noopener"
           class="flex flex-col items-center gap-2 text-paper hover:text-red transition-colors">
          <svg width="48" height="48" viewBox="0 0 24 24" fill="currentColor">
            <path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/>
          </svg>
          <span class="font-display text-xs tracking-widest uppercase">Moto Nineties</span>
        </a>
      </div>
    </div>
    <img src="/images/DuctTape-Long.png" alt="" aria-hidden="true" class="absolute left-1/2 pointer-events-none z-30"
         style="bottom: 0; transform: translateX(-50%) translateY(50%); width: 800px; max-width: 90%;" />
  </section>

  <!-- ── MERCH CTA ──────────────────────────────────────────────────────────── -->
  <section class="section relative bg-white" style="padding-top: 5rem; padding-bottom: 5rem;" id="merch-cta">
    <div class="max-w-3xl mx-auto text-center px-5">
      <img
        src="/images/merch/Merch-Title.webp"
        alt="Merch"
        class="mx-auto mb-6"
        style="max-width: 416px; width: 100%;"
        id="merch-cta-title"
      />
      <img
        src="/images/MErch-Group-Sm.png"
        alt="Moto Nineties Merch"
        class="mx-auto mb-6 w-full"
        style="max-width: 600px;"
        id="merch-cta-img"
      />
      <p class="font-display text-red uppercase tracking-widest mb-8" style="font-size: clamp(1.1rem, 2vw, 1.5rem);">
        First Drop Is Live Now
      </p>
      <a href="/merch"
         class="inline-flex items-center gap-3 text-paper font-display text-sm tracking-widest uppercase px-8 py-4 hover:bg-red transition-colors"
         style="background: #04377c;">
        Shop Limited Drop ⚡
      </a>
    </div>
    <img src="/images/BlackTape-Long.png" alt="" aria-hidden="true" class="absolute left-1/2 pointer-events-none z-30"
         style="bottom: 0; transform: translateX(-50%) translateY(50%); width: 800px; max-width: 90%;" />
  </section>

  <!-- ── RIDERS CTA ─────────────────────────────────────────────────────────── -->
  <section class="section relative" style="padding-top: 5rem; padding-bottom: 5rem;" id="riders-cta">
    <div class="absolute inset-0 overflow-hidden pointer-events-none">
      <img src="/images/Cut-of-crowd-2.jpg" alt="" class="w-full h-full object-cover" />
      <div class="absolute inset-0" style="background: rgba(4,55,124,0.7);"></div>
    </div>
    <div class="relative z-10 max-w-4xl mx-auto px-5 grid md:grid-cols-2 gap-8 items-center">
      <div id="riders-cta-copy">
        <p class="font-sans text-paper/60 text-xs tracking-[0.15em] uppercase mb-4">Hi Flyers</p>
        <h2 class="font-display text-paper uppercase leading-none mb-6" style="font-size: clamp(2.5rem, 5vw, 4.5rem);">
          The Riders
        </h2>
        <p class="font-sans text-paper/70 text-sm leading-relaxed mb-8 max-w-sm">
          McGrath. Emig. The kings of an era that changed the sport forever.
        </p>
        <a href="/the-riders"
           class="inline-flex items-center gap-3 border border-paper text-paper font-display text-sm tracking-widest uppercase px-8 py-4 hover:bg-paper hover:text-ink transition-colors">
          Meet the Riders →
        </a>
      </div>
      <div id="riders-cta-img" class="relative flex items-center justify-center" style="height: 560px;">
        <img src="/images/cards/mcgrath-front.png"    class="card-drop absolute w-60 drop-shadow-2xl" style="--rot: -18deg; --tx: -60px; --ty: 20px;"  alt="" />
        <img src="/images/cards/emig-front.png"       class="card-drop absolute w-60 drop-shadow-2xl" style="--rot: 8deg;  --tx: 30px;  --ty: -30px;" alt="" />
        <img src="/images/cards/pastrana-front.png"   class="card-drop absolute w-60 drop-shadow-2xl" style="--rot: -5deg; --tx: -20px; --ty: 60px;"  alt="" />
        <img src="/images/cards/carmichael-front.png" class="card-drop absolute w-60 drop-shadow-2xl" style="--rot: 22deg; --tx: 70px;  --ty: 10px;"  alt="" />
        <img src="/images/cards/hart-front.png"       class="card-drop absolute w-60 drop-shadow-2xl" style="--rot: -12deg; --tx: 10px; --ty: -60px;" alt="" />
      </div>
    </div>
    <img src="/images/DuctTape-Long.png" alt="" aria-hidden="true" class="absolute left-1/2 pointer-events-none z-30"
         style="bottom: 0; transform: translateX(-50%) translateY(50%); width: 800px; max-width: 90%;" />
  </section>

  <!-- ── SEE THE TRAILER ────────────────────────────────────────────────────── -->
  <section class="section relative bg-ink" style="padding-top: 10rem;" id="trailer-section">
    <div class="max-w-xl mx-auto text-center px-5 relative z-10">
      <img
        src="/images/LogoRough.png"
        alt="Moto Nineties"
        class="mx-auto mb-8"
        style="width: 180px;"
      />
      <h2 class="font-display text-paper uppercase leading-none mb-4" style="font-size: clamp(2rem, 4.5vw, 3.75rem); text-wrap: balance;">
        A Film by The Hammer Factory
      </h2>
      <a
        href="https://thehammerfactory.com/documentary/"
        target="_blank"
        rel="noopener"
        class="inline-flex items-center gap-3 border-2 border-paper text-paper font-display text-sm tracking-widest uppercase px-10 py-5 hover:bg-paper hover:text-ink transition-colors rounded-full"
        id="trailer-cta-btn"
      >
        <svg width="16" height="16" viewBox="0 0 20 20" fill="none">
          <path d="M6 4l12 6-12 6V4z" fill="currentColor"/>
        </svg>
        See the Trailer
      </a>
    </div>
  </section>

</Layout>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  const tl = gsap.timeline({ defaults: { ease: 'power2.out' } });

  // Nav slides in
  tl.from('#site-nav', { y: -20, opacity: 0, duration: 0.8 }, 0.1);

  // BG photo dramatic zoom pull-back
  gsap.fromTo('#hero-bg',
    { scale: 1.3, transformOrigin: 'center top' },
    { scale: 1.04, duration: 4.5, ease: 'power2.out' }
  );

  // Logo drops in
  tl.from('#hero-logo', { opacity: 0, y: 28, scale: 0.94, duration: 1.0 }, 0.6);

  // Tagline
  tl.from('#hero-tagline', { opacity: 0, y: 12, duration: 0.7 }, 1.2);

  // Rule
  tl.from('#hero-rule', { scaleX: 0, transformOrigin: 'left center', duration: 0.4 }, 1.6);

  // Sub text
  tl.from('#hero-sub', { opacity: 0, duration: 0.5 }, 1.8);

  // Seam tape slaps in
  tl.from('#seam-tape', { scaleX: 0, opacity: 0, duration: 0.35, transformOrigin: 'left center', ease: 'power3.out' }, 1.5);

  // Scroll hint fade
  gsap.to('#scroll-hint', {
    opacity: 0,
    scrollTrigger: { trigger: 'body', start: '80px top', scrub: true },
  });

  // ── War section ─────────────────────────────────────────────────────────────
  // Headline slams in and overshoots its resting rotation before settling
  gsap.from('#war-headline', {
    opacity: 0,
    y: 80,
    rotation: 10,
    scale: 0.88,
    duration: 1.1,
    ease: 'back.out(1.4)',
    scrollTrigger: { trigger: '#war-headline-wrap', start: 'top 85%' },
  });

  // Image sweeps in from the left with a slight skew that straightens
  gsap.from('#war-image', {
    opacity: 0,
    x: -70,
    skewY: 2,
    duration: 1.0,
    ease: 'power3.out',
    scrollTrigger: { trigger: '#war-image', start: 'top 88%' },
  });

  // Copy children stagger up
  gsap.from('#war-copy > *', {
    opacity: 0,
    y: 28,
    duration: 0.7,
    ease: 'power2.out',
    stagger: 0.12,
    scrollTrigger: { trigger: '#war-copy', start: 'top 88%' },
  });

  // ── Blow-Out Party section ───────────────────────────────────────────────────
  gsap.from('#party-headline', {
    opacity: 0,
    y: 40,
    duration: 0.9,
    ease: 'power3.out',
    scrollTrigger: { trigger: '#party-section', start: 'top 82%' },
  });

  // ── Merch CTA ────────────────────────────────────────────────────────────────
  gsap.from('#merch-cta-img', {
    opacity: 0,
    y: 40,
    duration: 0.9,
    ease: 'power2.out',
    scrollTrigger: { trigger: '#merch-cta', start: 'top 82%' },
  });

  // ── Riders CTA ───────────────────────────────────────────────────────────────
  gsap.from('#riders-cta-copy > *', {
    opacity: 0,
    x: -30,
    duration: 0.7,
    stagger: 0.1,
    ease: 'power2.out',
    scrollTrigger: { trigger: '#riders-cta', start: 'top 82%' },
  });

  // Cards drop in one by one from above, landing at their rotated positions
  gsap.utils.toArray('.card-drop').forEach((card: Element, i: number) => {
    const el = card as HTMLElement;
    const rot = el.style.getPropertyValue('--rot');
    const tx  = el.style.getPropertyValue('--tx');
    const ty  = el.style.getPropertyValue('--ty');
    gsap.fromTo(el,
      { opacity: 0, y: -180, x: tx, rotation: 0, scale: 0.7 },
      {
        opacity: 1,
        y: ty,
        x: tx,
        rotation: rot,
        scale: 1,
        duration: 0.55,
        ease: 'bounce.out',
        delay: i * 0.15,
        scrollTrigger: { trigger: '#riders-cta', start: 'top 80%' },
      }
    );
  });

  // ── Trailer CTA ──────────────────────────────────────────────────────────────
  gsap.from('#trailer-cta-btn', {
    opacity: 0,
    scale: 0.88,
    duration: 0.8,
    ease: 'back.out(1.6)',
    scrollTrigger: { trigger: '#trailer-section', start: 'top 82%' },
  });
</script>

<script is:inline>
  const SHEET_URL = 'https://script.google.com/a/macros/stateofthedesign.com/s/AKfycbxeeg87ssnV9QbeM-jVN_X79RDvDU5Z6qRHD9trJUZNGTCZaNTRTXHdsW6MaTprbSME/exec';

  function submitEmail(email, source, onSuccess) {
    fetch(SHEET_URL, {
      method: 'POST',
      mode: 'no-cors',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ email, source }),
    }).finally(onSuccess);
  }

  function handleHeroEmail(e) {
    e.preventDefault();
    const email = e.target.email.value.trim();
    submitEmail(email, 'hero', () => {
      document.getElementById('hero-email-block').innerHTML =
        '<p style="color:#f0ebe3;font-family:Inter,sans-serif;font-size:1rem;font-weight:500;">You\'re on the list. See you at the premiere.</p>';
    });
  }

  function handleEmailSubmit(e) {
    e.preventDefault();
    const email = e.target.email.value.trim();
    submitEmail(email, 'footer', () => {
      e.target.innerHTML = '<p style="color:#f0ebe3;font-family:Inter,sans-serif;font-size:0.875rem;">You\'re on the list. See you at the premiere.</p>';
    });
  }
</script>
