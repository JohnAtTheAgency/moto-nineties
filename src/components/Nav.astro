---
const links = [
  { href: '/the-film',        label: 'The Film' },
  { href: '/the-riders',      label: 'The Riders' },
  { href: '/merch',           label: 'Merch' },
  { href: '/where-to-watch',  label: 'Where to Watch' },
];

const current = Astro.url.pathname;
const isHome  = current === '/';
---

<!-- Full-width black tape at the very top — top edge clipped by viewport -->
<div class="fixed top-0 left-0 right-0 z-40 pointer-events-none overflow-hidden hidden lg:block" style="height: 60px;">
  <img src="/images/BlackTape-Long.png" alt="" class="w-full absolute" style="top: -18px;" />
</div>

<header class="fixed top-0 left-0 right-0 z-50 flex items-center justify-center px-6 overflow-visible" style="height: 60px;" id="site-nav">

  <!-- Logo + nav: grouped and centered together on inner pages -->
  <div class="flex items-center" style="gap: 30px;">

    <a href="/" class="shrink-0 hidden lg:block" style="align-self: flex-start; margin-top: 32px;">
      <img
        src="/images/Moto-Nineties-Logo-Simple.svg"
        alt="Moto Nineties"
        style="height: 58px; width: auto; filter: brightness(0) invert(1) drop-shadow(0 1px 4px rgba(0,0,0,0.95));"
      />
    </a>

    <!-- Desktop nav -->
    <nav class="hidden lg:flex items-center gap-7 whitespace-nowrap">
      {links.map(l => (
        <a
          href={l.href}
          class={`font-racing text-lg transition-all duration-150 leading-none inline-block hover:scale-105 hover:rotate-1 ${
            current.startsWith(l.href) ? 'text-red' : 'text-paper hover:text-red'
          }`}
        >
          {l.label}
        </a>
      ))}
      <!-- Instagram -->
      <a
        href="https://www.instagram.com/moto.nineties"
        target="_blank"
        rel="noopener"
        class="flex items-center gap-1.5 text-paper hover:text-red transition-colors"
      >
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
          <circle cx="12" cy="12" r="4"/>
          <circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none"/>
        </svg>
        <span class="font-sans text-sm tracking-wide">moto.nineties</span>
      </a>
    </nav>

  </div>

  <!-- Mobile menu button — absolute right -->
  <button id="menu-btn" aria-label="Open menu" class="absolute right-4 lg:hidden flex flex-col gap-2 p-2">
    <span class="block w-8 h-1 bg-paper transition-all" id="bar1"></span>
    <span class="block w-8 h-1 bg-paper transition-all" id="bar2"></span>
    <span class="block w-6 h-1 bg-paper transition-all" id="bar3"></span>
  </button>
</header>

<!-- Mobile menu overlay -->
<div
  id="mobile-menu"
  class="fixed inset-0 z-[60] flex flex-col items-center justify-center pointer-events-none"
  style="background: #04377c; opacity: 0; transition: opacity 0.35s ease;"
  aria-hidden="true"
>
  <!-- Close button -->
  <button
    id="menu-close"
    aria-label="Close menu"
    class="absolute top-5 right-5 flex flex-col gap-1.5 p-2"
  >
    <span class="block w-6 h-px bg-white transition-all" style="transform: translateY(4px) rotate(45deg);"></span>
    <span class="block w-6 h-px bg-white transition-all" style="transform: translateY(-4px) rotate(-45deg);"></span>
  </button>

  <!-- Logo -->
  <img
    src="/images/LogoRough.png"
    alt="Moto Nineties"
    style="width: 180px; margin-bottom: 3rem; filter: drop-shadow(0 2px 12px rgba(0,0,0,0.6)); opacity: 0; transform: translateY(16px); transition: opacity 0.4s ease 0.1s, transform 0.4s ease 0.1s;"
    class="menu-item"
  />

  <!-- Nav links -->
  {links.map((l, i) => (
    <a
      href={l.href}
      class="font-racing text-white menu-item block text-center leading-none"
      style={`font-size: clamp(2.25rem, 8vw, 3.5rem); margin-bottom: 1.25rem; opacity: 0; transform: translateY(20px); transition: opacity 0.4s ease ${0.15 + i * 0.07}s, transform 0.4s ease ${0.15 + i * 0.07}s, color 0.15s;`}
    >
      {l.label}
    </a>
  ))}

  <!-- Instagram -->
  <a
    href="https://www.instagram.com/moto.nineties"
    target="_blank"
    rel="noopener"
    class="flex items-center gap-2 menu-item"
    style="color: rgba(255,255,255,0.6); margin-top: 2rem; opacity: 0; transform: translateY(20px); transition: opacity 0.4s ease 0.45s, transform 0.4s ease 0.45s, color 0.15s;"
  >
    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
      <circle cx="12" cy="12" r="4"/>
      <circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none"/>
    </svg>
    <span class="font-sans text-base tracking-wide">moto.nineties</span>
  </a>
</div>

<style>
  #mobile-menu a:hover {
    color: #e63329 !important;
  }
  #mobile-menu.is-open {
    opacity: 1 !important;
    pointer-events: auto !important;
  }
  #mobile-menu.is-open .menu-item {
    opacity: 1 !important;
    transform: translateY(0) !important;
  }
  #mobile-menu a.menu-item {
    max-width: 260px;
  }
  #mobile-menu a.menu-item:nth-child(5) {
    font-size: clamp(1.91rem, 6.8vw, 2.98rem) !important;
  }
</style>

<script>
  const btn   = document.getElementById('menu-btn')!;
  const close = document.getElementById('menu-close')!;
  const menu  = document.getElementById('mobile-menu')!;
  const bar1  = document.getElementById('bar1')!;
  const bar2  = document.getElementById('bar2')!;
  const bar3  = document.getElementById('bar3')!;

  function openMenu() {
    menu.classList.add('is-open');
    menu.setAttribute('aria-hidden', 'false');
    document.body.style.overflow = 'hidden';
    bar1.style.transform = 'translateY(6px) rotate(45deg)';
    bar2.style.opacity   = '0';
    bar3.style.transform = 'translateY(-6px) rotate(-45deg)';
    bar3.style.width     = '1.5rem';
  }

  function closeMenu() {
    menu.classList.remove('is-open');
    menu.setAttribute('aria-hidden', 'true');
    document.body.style.overflow = '';
    bar1.style.transform = bar3.style.transform = '';
    bar2.style.opacity   = '1';
    bar3.style.width     = '1rem';
  }

  btn.addEventListener('click', openMenu);
  close.addEventListener('click', closeMenu);

  menu.querySelectorAll('a').forEach(a =>
    a.addEventListener('click', closeMenu)
  );
</script>
